# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/public
/package.json
/package-lock.json

/postcss.config.js
/postcss.config.mjs

/tailwind.config.js
/tailwind.config.mjs
/eslint.config.mjs
/jsconfig.json
/next.config.mjs
